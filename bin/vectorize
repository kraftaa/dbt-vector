#!/usr/bin/env bash
# One-shot vectorization: run dbt model and immediately fill embeddings.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
VECTORIZE_ENV_FILE="${VECTORIZE_ENV_FILE:-${ROOT_DIR}/.env.vectorize}"

# Load optional env file (KEY=VALUE lines) before applying defaults.
if [[ -f "${VECTORIZE_ENV_FILE}" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${VECTORIZE_ENV_FILE}"
  set +a
fi

DBT_CMD="${DBT:-dbt}"
PROFILE_DIR="${PROFILE_DIR:-${ROOT_DIR}}"
PROJECT_DIR="${PROJECT_DIR:-${ROOT_DIR}}"
SELECT_MODEL="${SELECT_MODEL:-vector_knowledge_base}"
INDEX_NAME="${INDEX_NAME:-knowledge_base}"
SCHEMA="${SCHEMA:-public}"
PROFILE_NAME="${PROFILE:-default}"
TARGET_NAME="${TARGET:-}"
PROFILE_FILE="${PROFILE_FILE:-${PROFILE_DIR}/profiles.yml}"
PYTHON_BIN="${PYTHON_BIN:-python3}"

# Embedding settings
EMBED_PROVIDER="${EMBED_PROVIDER:-local}"
EMBED_MODEL="${EMBED_MODEL:-sentence-transformers/all-MiniLM-L6-v2}"

# Parse vectorize-specific flags and pass the rest through to dbt.
PASSTHRU_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --embed-db-batch-size)
      export EMBED_DB_BATCH_SIZE="${2:-}"
      shift 2
      ;;
    --embed-dims)
      export EMBED_DIMS="${2:-}"
      shift 2
      ;;
    --embed-provider)
      EMBED_PROVIDER="${2:-}"
      shift 2
      ;;
    --embed-model)
      EMBED_MODEL="${2:-}"
      shift 2
      ;;
    --embed-local-model-path)
      export EMBED_LOCAL_MODEL_PATH="${2:-}"
      shift 2
      ;;
    --index-name)
      INDEX_NAME="${2:-}"
      shift 2
      ;;
    --schema)
      SCHEMA="${2:-}"
      shift 2
      ;;
    --help)
      cat <<'EOF'
Usage: ./bin/vectorize [vectorize flags] [dbt run args]

Vectorize flags:
  --embed-db-batch-size N       DB read/update batch size for Rust embedder
  --embed-dims N                embedding dimensions (must match model/table)
  --embed-provider NAME         local | openai | bedrock
  --embed-model NAME            embedding model id
  --embed-local-model-path DIR  local ONNX model folder (model.onnx/tokenizer.json)
  --index-name NAME             override target table/index name
  --schema NAME                 override target schema

Examples:
  ./bin/vectorize --select vector_knowledge_base_incremental --embed-db-batch-size 500
  ./bin/vectorize --embed-provider local --embed-model sentence-transformers/all-MiniLM-L6-v2 --embed-dims 384 --select vector_knowledge_base_incremental
EOF
      exit 0
      ;;
    *)
      PASSTHRU_ARGS+=("$1")
      shift
      ;;
  esac
done

# Forward explicit dbt args (e.g. --select model_name). If none provided, default to SELECT_MODEL.
RUN_ARGS=("${PASSTHRU_ARGS[@]}")
if [[ ${#RUN_ARGS[@]} -eq 0 ]]; then
  RUN_ARGS=(--select "${SELECT_MODEL}")
fi

MODEL_SELECTOR="${SELECT_MODEL}"
for ((i=0; i<${#RUN_ARGS[@]}; i++)); do
  if [[ "${RUN_ARGS[i]}" == "--select" || "${RUN_ARGS[i]}" == "-s" ]]; then
    if (( i + 1 < ${#RUN_ARGS[@]} )); then
      MODEL_SELECTOR="${RUN_ARGS[i+1]}"
    fi
  fi
done
# Best-effort normalize: package.model -> model
MODEL_NAME="${MODEL_SELECTOR##*.}"

# If PG* vars are unset, pull them from profiles.yml (postgres output)
if [[ -z "${PGHOST:-}" || -z "${PGPORT:-}" || -z "${PGUSER:-}" || -z "${PGDATABASE:-}" ]]; then
  if [[ -f "${PROFILE_FILE}" ]]; then
    if ! command -v "${PYTHON_BIN}" >/dev/null 2>&1; then
      PYTHON_BIN="python"
    fi
    if command -v "${PYTHON_BIN}" >/dev/null 2>&1; then
      profile_exports="$(
        "${PYTHON_BIN}" - <<'PY' "${PROFILE_FILE}" "${PROFILE_NAME}" "${TARGET_NAME}" 2>/dev/null || true
import os, shlex, sys
import yaml
profile_file, profile_name, target_name = sys.argv[1:4]
with open(profile_file, "r") as f:
    data = yaml.safe_load(f) or {}
profile = data.get(profile_name, {})
target = target_name or profile.get("target")
outputs = profile.get("outputs", {}) or {}
if not target:
    # fallback to first output
    target = next(iter(outputs.keys()), None)
cfg = outputs.get(target, {}) if target else {}
if cfg.get("type") != "postgres":
    sys.exit(0)
def emit_if_missing(k, v):
    if v is None:
        return
    if os.environ.get(k):
        return
    print(f"{k}={shlex.quote(str(v))}")
emit_if_missing("PGHOST", cfg.get("host"))
emit_if_missing("PGPORT", cfg.get("port"))
emit_if_missing("PGUSER", cfg.get("user"))
emit_if_missing("PGPASSWORD", cfg.get("password"))
emit_if_missing("PGDATABASE", cfg.get("dbname"))
emit_if_missing("SCHEMA", cfg.get("schema"))
PY
      )"
      if [[ -n "${profile_exports}" ]]; then
        eval "${profile_exports}"
      fi
    fi
  fi
fi

echo "[vectorize] running dbt model ${MODEL_NAME} (provider=${EMBED_PROVIDER}, model=${EMBED_MODEL})"
EMBED_PROVIDER="${EMBED_PROVIDER}" EMBED_MODEL="${EMBED_MODEL}" \
  "${DBT_CMD}" run --no-partial-parse --profiles-dir "${PROFILE_DIR}" --project-dir "${PROJECT_DIR}" "${RUN_ARGS[@]}"

# If INDEX_NAME/SCHEMA are still defaults, infer from dbt manifest for selected model.
if command -v "${PYTHON_BIN}" >/dev/null 2>&1; then
  manifest_exports="$(
    "${PYTHON_BIN}" - <<'PY' "${PROJECT_DIR}/target/manifest.json" "${MODEL_NAME}" "${INDEX_NAME}" "${SCHEMA}" 2>/dev/null || true
import json, os, shlex, sys
manifest_path, model_name, index_name, schema = sys.argv[1:5]
if not os.path.exists(manifest_path):
    raise SystemExit(0)
with open(manifest_path, "r", encoding="utf-8") as f:
    m = json.load(f)
nodes = (m.get("nodes") or {}).values()
node = None
for n in nodes:
    if n.get("resource_type") == "model" and n.get("name") == model_name:
        node = n
        break
if not node:
    raise SystemExit(0)
cfg = node.get("config") or {}
resolved_index = cfg.get("index_name") or node.get("alias") or node.get("name")
resolved_schema = node.get("schema")
if index_name == "knowledge_base" and resolved_index:
    print(f"INDEX_NAME={shlex.quote(str(resolved_index))}")
if schema == "public" and resolved_schema:
    print(f"SCHEMA={shlex.quote(str(resolved_schema))}")
PY
  )"
  if [[ -n "${manifest_exports}" ]]; then
    eval "${manifest_exports}"
  fi
fi

echo "[vectorize] generating embeddings via Rust into ${SCHEMA}.${INDEX_NAME}"
(
  cd "${ROOT_DIR}/rust/embedding_engine"
  PGHOST="${PGHOST:-localhost}" \
  PGPORT="${PGPORT:-5432}" \
  PGUSER="${PGUSER:-postgres}" \
  PGPASSWORD="${PGPASSWORD:-}" \
  PGDATABASE="${PGDATABASE:-postgres}" \
  SCHEMA="${SCHEMA}" INDEX_NAME="${INDEX_NAME}" \
  EMBED_PROVIDER="${EMBED_PROVIDER}" \
  EMBED_MODEL="${EMBED_MODEL}" EMBED_DIMS="${EMBED_DIMS:-1536}" \
  EMBED_DB_BATCH_SIZE="${EMBED_DB_BATCH_SIZE:-1000}" \
  cargo run --quiet --bin pg_embedder --release --
)

echo "[vectorize] done."
