# Copy to .env.vectorize and adjust values for your machine.

# ---- dbt wiring ----
DBT=/opt/homebrew/bin/dbt
PROFILE_DIR=.
PROJECT_DIR=.
PROFILE=default
TARGET=dev
SELECT_MODEL=vector_knowledge_base

# ---- embedding provider/model ----
# local | openai | bedrock
EMBED_PROVIDER=local
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIMS=384
# Required for EMBED_PROVIDER=local (folder must contain model.onnx + tokenizer.json)
EMBED_LOCAL_MODEL_PATH=$PWD/ml_model

# ---- provider auth/endpoint ----
# Required for EMBED_PROVIDER=openai
# OPENAI_API_KEY=
# Optional OpenAI-compatible endpoint override
# OPENAI_EMBED_URL=https://api.openai.com/v1/embeddings
# For bedrock, use normal AWS envs/role (AWS_REGION, AWS_PROFILE, IRSA, etc.)

# ---- postgres connection ----
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postgres
SCHEMA=public
INDEX_NAME=knowledge_base

# ---- batching/perf ----
# Rows read/written per DB batch by pg_embedder
EMBED_DB_BATCH_SIZE=1000
# Texts sent per provider call (OpenAI/local ONNX/Bedrock)
EMBED_MAX_BATCH=128
# HTTP retries/timeouts (OpenAI path)
EMBED_RETRIES=3
EMBED_TIMEOUT_SECS=60
# Local ONNX tokenizer max sequence length
EMBED_MAX_LEN=256

# ---- safety/debug ----
# EMBED_LIMIT=100
# EMBED_KEEP_SOURCE=1
# EMBED_LOG_BATCHES=1
# DBT_VECTORIZE_DROP_SOURCE_IN_DBT=1

# ---- search tuning ----
VECTOR_SEARCH_PROBES=10
# VECTOR_SEARCH_COLUMNS=doc_id,text,source,created_at
