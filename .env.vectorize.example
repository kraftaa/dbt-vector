# Copy to .env.vectorize and adjust values for your machine.

# dbt binary to run
DBT=/opt/homebrew/bin/dbt

# Embedding provider/model
EMBED_PROVIDER=local
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_LOCAL_MODEL_PATH=$PWD/ml_model
EMBED_DIMS=384

# Postgres connection for pg_embedder
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postgres
SCHEMA=public
INDEX_NAME=knowledge_base
